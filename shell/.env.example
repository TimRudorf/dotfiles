# ~/.env.example — Template für ~/.env auf dem Mac
# Kopiere diese Datei nach ~/.env und fülle die Werte aus:
#   cp ~/.env.example ~/.env && chmod 600 ~/.env
#
# Master-Template für das Schema: docker-compose/jarvis/.env.example im
# Repo TimRudorf/docker-compose. Bei Schema-Änderungen dort zuerst
# anpassen, dann hier synchron halten.
#
# Auf der Debian-VM lebt die analoge Datei unter /opt/stacks/jarvis/.env
# und wird von Docker Compose in den Jarvis-Container gereicht.

# ===== Anthropic =====
ANTHROPIC_API_KEY=

# ===== Bridge / Telegram (VM-only, auf Mac leer lassen) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_CHAT_ID=
BRIDGE_LOG_LEVEL=info
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=de
DOTFILES_REPO=https://github.com/TimRudorf/dotfiles.git
STOW_PACKAGES=claude

# ===== OpenAI =====
OPENAI_API_KEY=

# ===== GitHub - private (github.com) =====
GH_PRIVATE_TOKEN=

# ===== GitHub - work (EDP Enterprise) =====
GH_WORK_HOST=einsatzleitsoftware.ghe.com
GH_WORK_TOKEN=

# ===== Nextcloud - private =====
NC_PRIVATE_HOST=
NC_PRIVATE_USER=
NC_PRIVATE_PASSWORD=
NC_PRIVATE_WEBDAV=

# ===== Nextcloud - work (EDP Sharecloud) =====
NC_WORK_HOST=
NC_WORK_USER=
NC_WORK_PASSWORD=
NC_WORK_WEBDAV=

# ===== Zammad (nur work) =====
ZAMMAD_HOST=
ZAMMAD_TOKEN=

# ===== EDP-Spezifika =====
EDP_PROJECT_ROOT=
EDP_VM_HOST=
EDP_DESIGN_USER=
EDP_DESIGN_PASS=
EDP_DESIGN_FUNKTION=

# ===== DokuWiki (EDP) =====
DOKUWIKI_URL=
DOKUWIKI_USER=
DOKUWIKI_PASSWORD=

# ===== Mealie =====
MEALIE_URL=
MEALIE_TOKEN=

# ===== reMarkable =====
REMARKABLE_EMAIL=
REMARKABLE_PASSWORD=
RM_DEVICE_TOKEN=

# ===== Home-Media-Stack - Audiobookshelf =====
ABS_URL=
ABS_API_KEY=
ABS_RM_ROOT_FOLDER=

# ===== Home-Media-Stack - Radarr =====
RADARR_HOST=
RADARR_API_KEY=

# ===== Home-Media-Stack - Sonarr =====
SONARR_HOST=
SONARR_API_KEY=

# ===== Home-Media-Stack - Plex RSS =====
PLEX_WATCHLIST_RSS_URL=
PLEX_FRIENDS_WATCHLIST_RSS_URL=

# ===== Sonstige =====
PEXELS_TOKEN=
PUSHOVER_USER_KEY=
