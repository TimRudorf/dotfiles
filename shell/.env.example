# ~/.env.example — Template für ~/.env
# Kopiere diese Datei nach ~/.env und fülle die Werte aus:
#   cp ~/.env.example ~/.env && chmod 600 ~/.env

# === Mealie (Rezeptverwaltung) ===
MEALIE_URL=https://mealie.timrudorf.de
MEALIE_TOKEN=

# === Pexels (Stockfotos) ===
PEXELS_TOKEN=

# === OpenAI (Bildgenerierung) ===
OPENAI_TOKEN=

# === Zammad (Ticketsystem) ===
ZAMMAD_HOST=
ZAMMAD_TOKEN=

# === Nextcloud / Sharecloud ===
NC_HOST=
NC_WEBDAV=
NC_USER=
NC_PASSWORD=

# === EDP Entwicklungs-VM ===
EDP_VM_HOST=eifert-dev
