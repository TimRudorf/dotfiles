{
  "skillListingBudgetFraction": 0.02,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__claude_ai_Google_Calendar__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-block-google-calendar.sh"
          }
        ]
      },
      {
        "matcher": "mcp__bridge__request_approval",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-approval-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-version-bump-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-vault-autosync.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-vault-bash-autosync.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-repo-clean-check.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto"
}
