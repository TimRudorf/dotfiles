{
  "env": {
    "TELEGRAM_BOT_TOKEN": "8310884555:AAFsx0unYWI5ORkNwteG0zVD1F9EMNoCeSA",
    "TELEGRAM_CHAT_ID": "266706699"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skillListingBudgetFraction": 0.02,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__claude_ai_Google_Calendar__.*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-block-google-calendar.sh"
          }
        ]
      },
      {
        "matcher": "mcp__bridge__request_approval",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-approval-reminder.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-vault-autosync.sh"
          }
        ]
      }
    ]
  }
}
