{
  "env": {
    "TELEGRAM_BOT_TOKEN": "***REMOVED-LEAKED-TOKEN***",
    "TELEGRAM_CHAT_ID": "266706699"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/dotfiles/claude/scripts/jarvis-vault-autosync.sh"
          }
        ]
      }
    ]
  }
}
